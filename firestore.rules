rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Anyone can read departments (public data)
    match /departments/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Anyone can read courses (public data)
    match /courses/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Authenticated users can read and manage their own user data
    match /users/{uid} {
      allow read, write: if request.auth.uid == uid;
      
      // Bookmarks subcollection
      match /bookmarks/{document=**} {
        allow read, write: if request.auth.uid == uid;
      }
      
      // Recent courses subcollection
      match /recent_courses/{document=**} {
        allow read, write: if request.auth.uid == uid;
      }
    }

    // Contributors data (public read, authenticated write)
    match /contributors/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Papers/Past questions (public read, authenticated write)
    match /papers/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Notifications (authenticated read/write)
    match /notifications/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Admins collection (used to mark admin users)
    match /admins/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Default deny all
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
