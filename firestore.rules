rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helpers
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // --- ADMINS Collection ---
    // Store admin UIDs here. If a user exists in admins/{uid}, they have admin rights.
    match /admins/{uid} {
      allow read: if isAdmin();
      allow write: if false; // Admins managed only via Firebase Console for security
    }

    // --- USERS ---
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // --- DATA COLLECTIONS ---
    // PUBLIC READ: Everyone can see departments, courses, papers, contributors, notifications
    // WRITE: Only admins can modify data
    match /departments/{deptId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /contributors/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /papers/{paperId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /feature_interest/{id} {
      allow read: if true;
      allow write: if isAuthenticated(); // Users can track their own interests
    }

    match /notifications/{notificationId} {
      allow read: if true;
      allow write: if isAdmin(); // Only admins create notifications
    }
  }
}
