rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helpers
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function userCreateFields() {
      return [
        'name',
        'email',
        'departmentId',
        'level',
        'role',
        'isPremium',
        'bookmarks',
        'readNotifications',
        'recentCourses',
        'createdAt',
        'downloadsCount',
        'avatar',
        'fcmTokens',
        'notificationSettings'
      ];
    }

    function userSelfUpdateFields() {
      return ['name', 'departmentId', 'level', 'avatar', 'fcmTokens', 'downloadsCount', 'notificationSettings'];
    }

    function validStudentCreate() {
      return request.resource.data.keys().hasOnly(userCreateFields())
        && request.resource.data.role == 'student'
        && request.resource.data.isPremium == false
        && (!('downloadsCount' in request.resource.data) || request.resource.data.downloadsCount == 0);
    }

    function validStudentUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return changed.hasOnly(userSelfUpdateFields())
        && (!changed.hasAny(['downloadsCount'])
          || (
            (
              resource.data.downloadsCount is int
              && request.resource.data.downloadsCount == resource.data.downloadsCount + 1
            )
            || (
              !('downloadsCount' in resource.data)
              && request.resource.data.downloadsCount == 1
            )
          ));
    }

    // --- ADMINS Collection ---
    match /admins/{uid} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == uid);
      allow write: if false; 
    }

    // --- USERS ---
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && validStudentCreate();
      allow update: if (isOwner(userId) && validStudentUpdate()) || isAdmin();
      allow delete: if isAdmin();
      
      // --- USER SUBCOLLECTIONS ---
      match /bookmarks/{paperId} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      }
      
      match /read_notifications/{notificationId} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      }

      match /deleted_notifications/{notificationId} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      }
      
      match /recent_courses/{courseId} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      }
      
      match /downloaded_papers/{paperId} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      }

      match /prompt_state/{promptId} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      }
    }

    // --- SYSTEM CONFIG ---
    // Added rule to allow everyone to read global config, but only admins to modify it
    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- ADMIN COLLECTIONS ---
    match /admin_submissions/{submissionId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    match /admin_notifications_queue/{notificationId} {
      allow read, write: if isAdmin();
    }

    match /admin_logs/{logId} {
      allow read, write: if isAdmin();
    }

    // --- DATA COLLECTIONS ---
    match /departments/{deptId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin();
      
      match /papers/{paperId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }
    
    // --- TOP-LEVEL PAPERS (used by student views & admin uploads) ---
    match /papers/{paperId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /contributors/{id} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
        || (
          isAuthenticated()
          && request.auth.uid == id
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['avatar', 'name'])
        );
    }
    
    match /feature_interest/{id} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin()
        || (
          isAuthenticated()
          && resource.data.userId == request.auth.uid
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.feature == resource.data.feature
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['userName', 'userEmail', 'userAvatar', 'timestamp'])
        );
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- PREMIUM & FEEDBACK ---
    match /pricingFeedback/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    match /student_feedback/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create, update: if isAuthenticated()
        && request.auth.uid == userId
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /timetables/{deptId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /repeated_questions/{deptId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
