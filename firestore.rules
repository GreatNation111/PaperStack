rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper
    function isAuthenticated() {
      return request.auth != null;
    }

    // --- USERS ---
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // --- ADMINS ---
    match /admins/{userId} {
      allow read: if isAuthenticated(); 
      allow write: if false; 
    }

    // --- DATA COLLECTIONS ---
    // PUBLIC READ: Everyone can see departments, courses, papers, contributors, notifications
    // WRITE: Only authenticated users (for seeding for now)
    match /departments/{deptId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    match /contributors/{id} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /papers/{paperId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    match /feature_interest/{id} {
      allow read: if true;
      allow write: if isAuthenticated(); 
    }

    match /notifications/{notificationId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
  }
}
