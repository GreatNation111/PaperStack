rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helpers
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Development/Seeding: Allow unauthenticated writes to seed collection
    match /seed/{document=**} {
      allow read, write: if true;
    }

    // --- ADMINS Collection ---
    match /admins/{uid} {
      allow read: if true; 
      allow write: if false; 
    }

    // --- USERS ---
    match /users/{userId} {
      // FIX: Added || isAdmin() to allow you to see other user profiles in management
      allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      
      // --- USER SUBCOLLECTIONS ---
      match /bookmarks/{paperId} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      }
      
      match /read_notifications/{notificationId} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      }
      
      match /recent_courses/{courseId} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      }
    }

    // --- SYSTEM CONFIG ---
    // Added rule to allow everyone to read global config, but only admins to modify it
    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- ADMIN COLLECTIONS ---
    match /admin_submissions/{submissionId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    match /admin_notifications_queue/{notificationId} {
      allow read, write: if isAdmin();
    }

    match /admin_logs/{logId} {
      allow read, write: if isAdmin();
    }

    // --- DATA COLLECTIONS ---
    match /departments/{deptId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin();
      
      match /papers/{paperId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }
    
    // --- TOP-LEVEL PAPERS (used by student views & admin uploads) ---
    match /papers/{paperId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /contributors/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /feature_interest/{id} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /notifications/{notificationId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- PREMIUM & FEEDBACK ---
    match /pricingFeedback/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    match /timetables/{deptId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /repeated_questions/{deptId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
