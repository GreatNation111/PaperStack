# =============================================================================
# PaperStack Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
#
# cp .env.example .env.local
# =============================================================================

# -----------------------------------------------------------------------------
# Firebase Client Config (public, used in browser)
# These are safe to expose in frontend code. App security depends on
# Firebase Security Rules, not on keeping these secret.
# -----------------------------------------------------------------------------
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Firebase Cloud Messaging VAPID key (for push notifications)
VITE_FIREBASE_VAPID_KEY=

# -----------------------------------------------------------------------------
# Firebase Admin SDK (server-only, used by Vercel serverless functions)
# These are SECRET. They must NEVER be prefixed with VITE_ and must NEVER
# be imported into client/browser code. They are only accessible via
# process.env in server-side API routes (e.g. api/send-push.ts).
# -----------------------------------------------------------------------------
FB_SA_PROJECT_ID=
FB_SA_CLIENT_EMAIL=
FB_SA_PRIVATE_KEY=
